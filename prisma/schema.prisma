generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model with role-based access
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  role              UserRole  @default(STUDENT)
  status            UserStatus @default(PENDING)
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  lastLoginIp       String?
  loginCount        Int       @default(0)
  resetToken        String?
  resetTokenExpiry  DateTime?
  
  // Relations
  student           Student?
  doctorProfile     DoctorProfile?
  adminProfile      AdminProfile?
  sessions          Session[]
  accounts          Account[]
  notifications     Notification[]
  loginHistory      LoginHistory[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Book {
  id           String   @id @default(cuid())
  name         String
  type         String
  size         String
  url          String
  departmentId String?
  academicYear Int?
  createdAt    DateTime @default(now())

  department   Department? @relation(fields: [departmentId], references: [id])
}

// Student profile
model Student {
  id                String   @id @default(cuid())
  userId            String   @unique
  studentCode       String   @unique
  departmentId      String
  academicYear      Int
  phone             String?
  barcode           String?  @unique
  qrCode            String?  @unique
  blocked           Boolean  @default(false)
  approvedAt        DateTime?
  approvedBy        String?
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department @relation(fields: [departmentId], references: [id])
  attendances       Attendance[]
  assignmentSubmissions AssignmentSubmission[]
  quizAttempts      QuizAttempt[]
  examResults       ExamResult[]
  
  @@map("students")
  @@index([departmentId])
  @@index([academicYear])
  @@index([userId])
}

// Doctor profile
model DoctorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String?
  bio         String?  @db.Text
  specialties String[]
  phone       String?
  whatsapp    String?
  facebook    String?
  instagram   String?
  twitter     String?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  
  @@map("doctor_profiles")
}

// Admin profile
model AdminProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  permissions String[]
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("admin_profiles")
}

// Department model
model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  nameAr      String?
  code        String    @unique
  description String?   @db.Text
  level       Int       @default(1)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  // Relations
  subjects            Subject[]
  students            Student[]
  books               Book[]
  
  @@map("departments")
}

// Subject model
model Subject {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?  @db.Text
  departmentId  String
  academicYear  Int
  semester      Int      @default(1)
  doctorId      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  department    Department @relation(fields: [departmentId], references: [id])
  doctor        DoctorProfile? @relation(fields: [doctorId], references: [id])
  attendances   AttendanceSession[]
  assignments   Assignment[]
  quizzes       Quiz[]
  lectureSlides LectureSlide[]
  zoomLectures  ZoomLecture[]
  eLibraryItems ELibraryItem[]
  examResults   ExamResult[]
  
  @@map("subjects")
}

// Attendance session
model AttendanceSession {
  id           String    @id @default(cuid())
  subjectId    String?
  departmentId String?
  academicYear Int?
  title        String?
  openTime     DateTime
  closeTime    DateTime
  isOpen       Boolean   @default(true)
  createdBy    String
  createdAt    DateTime  @default(now())
  
  // Relations
  subject      Subject?    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attendances  Attendance[]
  
  @@map("attendance_sessions")
}

// Attendance record
model Attendance {
  id                String   @id @default(cuid())
  studentId         String
  sessionId         String
  timestamp         DateTime @default(now())
  deviceInfo        String?
  ipAddress         String?
  userAgent         String?
  location          String?
  verificationMethod String  @default("MANUAL")
  
  // Relations
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session           AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, sessionId])
  @@map("attendances")
  @@index([studentId])
  @@index([sessionId])
}

// Assignment
model Assignment {
  id            String   @id @default(cuid())
  subjectId     String?
  departmentId  String?
  academicYear  Int?
  title         String
  description   String?  @db.Text
  deadline      DateTime
  maxScore      Int      @default(100)
  allowUpload   Boolean  @default(true)
  fileUrl       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  subject       Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions   AssignmentSubmission[]
  
  @@map("assignments")
  @@index([departmentId])
  @@index([academicYear])
  @@index([subjectId])
}

// Assignment submission
model AssignmentSubmission {
  id            String   @id @default(cuid())
  assignmentId  String
  studentId     String
  fileUrl       String?
  notes         String?  @db.Text
  submittedAt   DateTime @default(now())
  score         Int?
  feedback      String?  @db.Text
  gradedAt      DateTime?
  gradedBy      String?
  status        SubmissionStatus @default(SUBMITTED)
  
  // Relations
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
  @@index([studentId])
  @@index([assignmentId])
}

// Quiz
model Quiz {
  id            String   @id @default(cuid())
  subjectId     String?
  departmentId  String?
  academicYear  Int?
  title         String
  description   String?  @db.Text
  timeLimit     Int
  maxAttempts   Int      @default(1)
  passingScore  Int      @default(60)
  shuffleQuestions Boolean @default(true)
  showCorrectAnswers Boolean @default(true)
  isPublished   Boolean  @default(false)
  startTime     DateTime?
  endTime       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  subject       Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      QuizAttempt[]
  
  @@map("quizzes")
}

// Question
model Question {
  id            String       @id @default(cuid())
  quizId        String
  type          QuestionType @default(MULTIPLE_CHOICE)
  question      String       @db.Text
  options       String[]
  correctAnswer String
  explanation   String?      @db.Text
  points        Int          @default(1)
  order         Int          @default(0)
  
  // Relations
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  @@map("questions")
}

// Quiz attempt
model QuizAttempt {
  id            String   @id @default(cuid())
  quizId        String
  studentId     String
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  score         Int?
  maxScore      Int?
  percentage    Float?
  answers       Json?
  timeSpent     Int?
  ipAddress     String?
  deviceInfo    String?
  status        AttemptStatus @default(IN_PROGRESS)
  
  // Relations
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@map("quiz_attempts")
  @@index([studentId])
  @@index([quizId])
}

// Zoom lecture
model ZoomLecture {
  id          String   @id @default(cuid())
  subjectId   String
  title       String
  description String?  @db.Text
  meetingUrl  String
  meetingId   String?
  password    String?
  scheduledAt DateTime
  duration    Int
  isRecorded  Boolean  @default(false)
  recordingUrl String?
  createdAt   DateTime @default(now())
  
  // Relations
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  @@map("zoom_lectures")
}

// Lecture slides & videos
model LectureSlide {
  id          String   @id @default(cuid())
  subjectId   String?
  title       String
  description String?  @db.Text
  fileUrl     String
  fileType    String   @default("pdf")
  fileSize    Int?
  order       Int      @default(0)
  uploadedAt  DateTime @default(now())
  uploadedBy  String
  
  // Relations
  subject     Subject? @relation(fields: [subjectId], references: [id])
  
  @@map("lecture_slides")
}

// E-Library items
model ELibraryItem {
  id          String   @id @default(cuid())
  subjectId   String?
  title       String
  author      String?
  description String?  @db.Text
  category    LibraryCategory @default(REQUIRED_TEXTBOOK)
  fileUrl     String?
  externalUrl String?
  coverImage  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  // Relations
  subject     Subject? @relation(fields: [subjectId], references: [id])
  
  @@map("e_library_items")
}

// Exam results
model ExamResult {
  id          String   @id @default(cuid())
  subjectId   String
  studentId   String
  examType    String   @default("FINAL")
  score       Float
  maxScore    Float    @default(100)
  percentage  Float
  grade       String?
  semester    Int
  academicYear Int
  notes       String?  @db.Text
  publishedAt DateTime @default(now())
  publishedBy String
  
  // Relations
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([subjectId, studentId, examType, semester, academicYear])
  @@map("exam_results")
  @@index([studentId])
  @@index([subjectId])
}

// Notifications
model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String   @db.Text
  type        NotificationType @default(GENERAL)
  isRead      Boolean  @default(false)
  data        Json?
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
  @@index([userId])
  @@index([isRead])
}

// Login history
model LoginHistory {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String?
  userAgent   String?
  deviceInfo  String?
  location    String?
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("login_history")
}

// System configuration
model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  
  @@map("system_config")
}

// Role detection rules
model RoleRule {
  id          String   @id @default(cuid())
  pattern     String
  role        UserRole
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  
  @@map("role_rules")
}

// Enums
enum UserRole {
  STUDENT
  DOCTOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum LibraryCategory {
  REQUIRED_TEXTBOOK
  RECOMMENDED_BOOK
  PROJECT_TOPIC
  REPORT_TEMPLATE
  REFERENCE_MATERIAL
}

enum NotificationType {
  GENERAL
  APPROVAL
  ASSIGNMENT
  QUIZ
  ATTENDANCE
  ANNOUNCEMENT
  EXAM_RESULT
}
