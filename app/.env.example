# Database (with pgbouncer for serverless/pooled connections)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct connection for migrations
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
# Comma-separated list of emails that should be treated as DOCTOR accounts
DOCTOR_EMAILS="doctor@dr-emad-edu.com"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
FROM_EMAIL="noreply@dr-emad-edu.com"
FROM_NAME="Dr. Emad Bayuome Educational System"

# App Config
APP_NAME="Dr. Emad Bayuome Educational System"
APP_URL="http://localhost:3000"

# File Upload (Optional - for S3)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""

# QR Code Config
QR_CODE_BASE_URL="http://localhost:3000"

# Security
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_WINDOW="900000"

# Feature Flags
ENABLE_REGISTRATION="true"
ENABLE_QUIZZES="true"
ENABLE_ATTENDANCE="true"
